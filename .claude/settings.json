{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-start.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-end.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check_test_safety.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/skills/safe-commit/scripts/pre-commit-hook.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/skill_usage_log.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check_secrets_read.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pre-edit-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/check_filesystem_path.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/agents_schema_guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-tool-use-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-edit-check.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/correction-detection.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/subagent-start.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
