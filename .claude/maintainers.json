{
  "_doc": "Two-level maintainer model. Global maintainers can modify any protected file. Scoped maintainers are restricted to their repos.",                                                                                                                
  "global": [                                                                                                                                                                                                                                               
    "dpinna@protonmail.com"
  ],                                                                                                                                                                                                                                                        
  "scopes": {                                                                                                                                                                                                                                               
    "{{PROJECT_NAME}}": {
      "maintainers": ["dpinna@protonmail.com"],                                                                                                                                                                                                             
      "protected_paths": [".claude/", "CLAUDE.md", "scripts/", "docs/"]                                                                                                                                                                                     
    }                                                                                                                                                                                                                                                       
  }                                                                                                                                                                                                                                                         
}                                                                                                                                                                                                                                                           
