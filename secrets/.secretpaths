# Protected path patterns — one per line
# Lines starting with # are comments. Blank lines ignored.
# Patterns are matched against absolute resolved paths.
# Use shell glob syntax: * matches within a dir, ** matches across dirs.

# Project secrets directory
secrets/*

# Environment files (anywhere in project)
*.env
*.env.*
.env*

# System credential stores
~/.ssh/*
~/.aws/*
~/.gnupg/*
~/.config/gcloud/*
~/.kube/config

# Private keys
*.pem
*.key
*id_rsa*
*id_ed25519*
