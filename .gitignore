# Logs
logs/*.log

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Swarm state (local to each machine)
swarm/*.db
swarm/*.db-wal
swarm/*.db-shm

# Session state (local, gitignored)
.session-identity
.session-stats
.push-logs.lock

# GitNexus indexes (rebuilt on demand)
.gitnexus/
AGENTS.md

# Secrets (directory tracked, contents ignored)
secrets/*
!secrets/.gitkeep
!secrets/.secretpaths

# Local settings
.claude/settings.local.json
